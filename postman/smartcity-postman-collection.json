{
	"info": {
		"_postman_id": "smartcity-platform-full",
		"name": "TrashTrack Smart City Platform",
		"description": "Full API Collection — OAuth, Smart Bin, Fleet, Citizen Report, ML, IoT\n\nCara pakai:\n1. Import collection + environment\n2. Aktifkan environment 'Smart City - Local'\n3. Jalankan '1. Login Admin' dulu\n4. Jalankan '2. IoT Token' untuk test telemetry\n5. Test sisanya sesuai urutan folder",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "0. Health Check",
			"item": [
				{
					"name": "Gateway Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Gateway OK', () => pm.expect(pm.response.json().data.gateway).to.equal('ok'));"
					]}}]
				},
				{
					"name": "OAuth Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{oauthUrl}}/health", "host": ["{{oauthUrl}}"], "path": ["health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('OAuth running', () => pm.expect(pm.response.json().service).to.equal('oauth-server'));"
					]}}]
				},
				{
					"name": "ML Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "http://localhost:5000/health", "host": ["http://localhost:5000"], "path": ["health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Models loaded', () => pm.expect(pm.response.json().models_loaded).to.equal(3));"
					]}}]
				}
			]
		},
		{
			"name": "1. OAuth",
			"item": [
				{
					"name": "Login Admin (Password Grant)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}" },
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has access_token', () => pm.expect(json.data).to.have.property('access_token'));",
						"if (json.data) {",
						"  pm.environment.set('accessToken', json.data.access_token);",
						"  pm.environment.set('refreshToken', json.data.refresh_token);",
						"}"
					]}}]
				},
				{
					"name": "IoT Token (Client Credentials)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"iot-device\",\n  \"client_secret\": \"iot-secret\"\n}" },
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Scope is service', () => pm.expect(json.data.scope).to.equal('service'));",
						"if (json.data) pm.environment.set('iotToken', json.data.access_token);"
					]}}]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"refresh_token\": \"{{refreshToken}}\"\n}" },
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"if (json.data) {",
						"  pm.environment.set('accessToken', json.data.access_token);",
						"  pm.environment.set('refreshToken', json.data.refresh_token);",
						"}"
					]}}]
				}
			]
		},
		{
			"name": "2. Smart Bin",
			"item": [
				{
					"name": "List All Bins",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/bins", "host": ["{{baseUrl}}"], "path": ["api", "bins"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has bins array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
						"pm.test('Has 10 bins', () => pm.expect(pm.response.json().data.length).to.equal(10));"
					]}}]
				},
				{
					"name": "Detail Bin (id=1)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/bins/1", "host": ["{{baseUrl}}"], "path": ["api", "bins", "1"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Bin code correct', () => pm.expect(pm.response.json().data.bin_code).to.equal('BIN-Z1-01'));"
					]}}]
				},
				{
					"name": "Set Bin Maintenance (id=4)",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/bins/4/maintenance", "host": ["{{baseUrl}}"], "path": ["api", "bins", "4", "maintenance"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status is Maintenance', () => pm.expect(pm.response.json().data.status).to.equal('Maintenance'));"
					]}}]
				}
			]
		},
		{
			"name": "3. IoT Telemetry",
			"item": [
				{
					"name": "Telemetry Normal (BIN-Z1-01)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{iotToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"bin_id\": \"BIN-Z1-01\",\n  \"fill_level\": 45.5,\n  \"gas_level\": 150,\n  \"temperature\": 30.0,\n  \"calibrated_height\": 98.0,\n  \"latitude\": -6.1944,\n  \"longitude\": 106.8318\n}" },
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('Volume updated', () => pm.expect(json.data.current_volume_percentage).to.equal(45.5));",
						"pm.test('Tinggi updated', () => pm.expect(json.data.tinggi).to.equal(98));",
						"pm.test('ML predictions exist', () => pm.expect(json.data).to.have.property('ml_predictions'));",
						"pm.test('No dispatch (not critical)', () => pm.expect(json.data.ml_predictions.dispatch).to.be.null);"
					]}}]
				},
				{
					"name": "Telemetry Critical — Trigger Auto-Dispatch (BIN-Z3-01)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{iotToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"bin_id\": \"BIN-Z3-01\",\n  \"fill_level\": 95.0,\n  \"gas_level\": 600,\n  \"temperature\": 35.0,\n  \"calibrated_height\": 120.0,\n  \"latitude\": -6.2383,\n  \"longitude\": 106.8000\n}" },
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('Priority is Urgent or Critical', () => {",
						"  const p = json.data.ml_predictions.priority;",
						"  pm.expect(['Urgent','Critical']).to.include(p);",
						"});",
						"pm.test('Dispatch triggered', () => {",
						"  const d = json.data.ml_predictions.dispatch;",
						"  pm.expect(d).to.not.be.null;",
						"  if (d && d.schedule_id) pm.environment.set('lastScheduleId', d.schedule_id);",
						"});"
					]}}]
				},
				{
					"name": "[401] Telemetry Tanpa Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"bin_id\": \"BIN-Z1-01\",\n  \"fill_level\": 50.0\n}" },
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 401', () => pm.response.to.have.status(401));"
					]}}]
				}
			]
		},
		{
			"name": "4. ML Predictions",
			"item": [
				{
					"name": "Predict Fill Rate",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"jam\": 14,\n  \"suhu_cuaca\": 32.0,\n  \"volume_sekarang\": 45.0,\n  \"latitude\": -6.1944,\n  \"longitude\": 106.8318,\n  \"is_weekend\": 0\n}" },
						"url": { "raw": "{{baseUrl}}/predict/fill-rate", "host": ["{{baseUrl}}"], "path": ["predict", "fill-rate"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has hours_until_full', () => pm.expect(pm.response.json()).to.have.property('hours_until_full'));"
					]}}]
				},
				{
					"name": "Predict Priority",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"volume_sekarang\": 85.0,\n  \"kadar_metana\": 30.0,\n  \"laporan_warga\": 3\n}" },
						"url": { "raw": "{{baseUrl}}/predict/priority", "host": ["{{baseUrl}}"], "path": ["predict", "priority"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has pickup_priority', () => {",
						"  const p = pm.response.json().pickup_priority;",
						"  pm.expect(['Low','Medium','Urgent','Critical']).to.include(p);",
						"});"
					]}}]
				},
				{
					"name": "Detect Anomaly",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"jarak_ultrasonik\": 25.0,\n  \"delta_volume_sec\": -5.5,\n  \"suhu_cuaca\": 38.2\n}" },
						"url": { "raw": "{{baseUrl}}/detect/anomaly", "host": ["{{baseUrl}}"], "path": ["detect", "anomaly"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Anomaly detected', () => pm.expect(pm.response.json().is_anomaly).to.be.true);"
					]}}]
				}
			]
		},
		{
			"name": "5. Fleet",
			"item": [
				{
					"name": "List All Trucks",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/fleet/trucks", "host": ["{{baseUrl}}"], "path": ["api", "fleet", "trucks"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has trucks', () => pm.expect(pm.response.json().data).to.be.an('array'));"
					]}}]
				},
				{
					"name": "Register New Truck",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"license_plate\": \"B 9999 TST\",\n  \"driver_name\": \"Test Driver\",\n  \"max_capacity_ton\": 2.0\n}" },
						"url": { "raw": "{{baseUrl}}/api/fleet/trucks", "host": ["{{baseUrl}}"], "path": ["api", "fleet", "trucks"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('Truck created', () => pm.expect(pm.response.json().data.license_plate).to.equal('B 9999 TST'));"
					]}}]
				},
				{
					"name": "Driver Check-In",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"license_plate\": \"B 9999 TST\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/fleet/driver-checkin", "host": ["{{baseUrl}}"], "path": ["api", "fleet", "driver-checkin"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status Available', () => pm.expect(pm.response.json().data.current_status).to.equal('Available'));"
					]}}]
				},
				{
					"name": "Complete Schedule",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"execution_status\": \"Completed\"\n}" },
						"url": { "raw": "{{baseUrl}}/api/fleet/schedules/{{lastScheduleId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "fleet", "schedules", "{{lastScheduleId}}", "status"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					]}}]
				}
			]
		},
		{
			"name": "6. Citizen Report",
			"item": [
				{
					"name": "Submit Report (form-data + photo)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "reporter_name", "value": "Budi Santoso", "type": "text" },
								{ "key": "reporter_phone", "value": "081234567001", "type": "text" },
								{ "key": "issue_description", "value": "Tong sampah meluber di depan pasar", "type": "text" },
								{ "key": "geo_coordinate", "value": "-6.1944,106.8318", "type": "text" },
								{ "key": "photo", "type": "file", "src": "" }
							]
						},
						"url": { "raw": "{{baseUrl}}/api/reports", "host": ["{{baseUrl}}"], "path": ["api", "reports"] },
						"description": "Upload foto JPG/PNG (max 2MB). Klik 'Select Files' di field photo."
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('Status Pending', () => pm.expect(json.data.verification_status).to.equal('Pending'));",
						"if (json.data) pm.environment.set('lastReportId', json.data.id);"
					]}}]
				},
				{
					"name": "Verify Report",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/reports/{{lastReportId}}/verify", "host": ["{{baseUrl}}"], "path": ["api", "reports", "{{lastReportId}}", "verify"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status Reviewed', () => pm.expect(pm.response.json().data.verification_status).to.equal('Reviewed'));"
					]}}]
				},
				{
					"name": "Dispatch Truck to Report",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": { "raw": "{{baseUrl}}/api/reports/{{lastReportId}}/dispatch", "host": ["{{baseUrl}}"], "path": ["api", "reports", "{{lastReportId}}", "dispatch"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status Dispatched', () => pm.expect(pm.response.json().data.report.verification_status).to.equal('Dispatched'));",
						"pm.test('Truck assigned', () => pm.expect(pm.response.json().data.truck).to.have.property('license_plate'));"
					]}}]
				}
			]
		}
	]
}
