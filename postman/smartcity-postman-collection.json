{
	"info": {
		"_postman_id": "smartcity-platform-sprint1",
		"name": "Smart City Platform",
		"description": "Smart City Integrated Platform — API Collection\nSprint 1: OAuth Server & API Gateway\n\nCara pakai:\n1. Import collection ini\n2. Import environment 'Smart City - Local'\n3. Aktifkan environment\n4. Jalankan 'Password Grant' dulu agar accessToken terisi otomatis\n5. Jalankan request lainnya sesuai urutan",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "OAuth Server (port 3002)",
			"description": "Semua endpoint langsung ke OAuth Server di port 3002",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{oauthUrl}}/health",
							"host": ["{{oauthUrl}}"],
							"path": ["health"]
						},
						"description": "Cek apakah OAuth Server berjalan"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Status is success', () => {",
									"  pm.expect(json.status).to.equal('success');",
									"});",
									"",
									"pm.test('Service is oauth-server', () => {",
									"  pm.expect(json.service).to.equal('oauth-server');",
									"});",
									"",
									"pm.test('Has timestamp', () => {",
									"  pm.expect(json).to.have.property('timestamp');",
									"});"
								]
							}
						}
					],
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"status\": \"success\",\n  \"code\": 200,\n  \"message\": \"OAuth Server is running\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Password Grant",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/token",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "token"]
						},
						"description": "Login sebagai user (admin/warga). Menghasilkan access_token + refresh_token.\nToken akan otomatis tersimpan ke environment variable."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Has access_token', () => {",
									"  pm.expect(json.data).to.have.property('access_token');",
									"});",
									"",
									"pm.test('Has refresh_token', () => {",
									"  pm.expect(json.data).to.have.property('refresh_token');",
									"});",
									"",
									"pm.test('token_type is Bearer', () => {",
									"  pm.expect(json.data.token_type).to.equal('Bearer');",
									"});",
									"",
									"pm.test('expires_in is 3600', () => {",
									"  pm.expect(json.data.expires_in).to.equal(3600);",
									"});",
									"",
									"pm.test('Service is oauth-server', () => {",
									"  pm.expect(json.service).to.equal('oauth-server');",
									"});",
									"",
									"if (json.data && json.data.access_token) {",
									"  pm.environment.set('accessToken', json.data.access_token);",
									"  console.log('✅ accessToken saved to environment');",
									"}",
									"",
									"if (json.data && json.data.refresh_token) {",
									"  pm.environment.set('refreshToken', json.data.refresh_token);",
									"  console.log('✅ refreshToken saved to environment');",
									"}"
								]
							}
						}
					],
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"status\": \"success\",\n  \"code\": 200,\n  \"data\": {\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"token_type\": \"Bearer\",\n    \"expires_in\": 3600,\n    \"refresh_token\": \"uuid-uuid-uuid...\",\n    \"scope\": \"read write\"\n  },\n  \"message\": \"Token issued successfully\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						},
						{
							"name": "401 Wrong Password",
							"status": "Unauthorized",
							"code": 401,
							"body": "{\n  \"status\": \"error\",\n  \"code\": 401,\n  \"message\": \"Invalid username or password\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Password Grant (warga1)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"username\": \"warga1\",\n  \"password\": \"warga123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/token",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "token"]
						},
						"description": "Login sebagai warga biasa (role: citizen)"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Has access_token', () => {",
									"  pm.expect(json.data).to.have.property('access_token');",
									"});",
									"",
									"if (json.data && json.data.access_token) {",
									"  pm.environment.set('accessTokenWarga', json.data.access_token);",
									"  console.log('✅ accessTokenWarga saved to environment');",
									"}"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Client Credentials Grant (IoT)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"iot-device\",\n  \"client_secret\": \"iot-secret\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/token",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "token"]
						},
						"description": "Token untuk IoT device / komunikasi antar service. Tidak menghasilkan refresh_token."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Has access_token', () => {",
									"  pm.expect(json.data).to.have.property('access_token');",
									"});",
									"",
									"pm.test('No refresh_token (expected untuk client_credentials)', () => {",
									"  pm.expect(json.data).to.not.have.property('refresh_token');",
									"});",
									"",
									"pm.test('Scope is service', () => {",
									"  pm.expect(json.data.scope).to.equal('service');",
									"});",
									"",
									"if (json.data && json.data.access_token) {",
									"  pm.environment.set('iotToken', json.data.access_token);",
									"  console.log('✅ iotToken saved to environment');",
									"}"
								]
							}
						}
					],
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"status\": \"success\",\n  \"code\": 200,\n  \"data\": {\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"token_type\": \"Bearer\",\n    \"expires_in\": 3600,\n    \"scope\": \"service\"\n  },\n  \"message\": \"Token issued successfully\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Refresh Token Grant",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"refresh_token\": \"{{refreshToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/token",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "token"]
						},
						"description": "Perpanjang sesi tanpa login ulang. Jalankan 'Password Grant' dulu agar {{refreshToken}} terisi.\nToken lama akan di-rotate (dihapus), token baru diterbitkan."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Got new access_token', () => {",
									"  pm.expect(json.data).to.have.property('access_token');",
									"});",
									"",
									"pm.test('Got new refresh_token', () => {",
									"  pm.expect(json.data).to.have.property('refresh_token');",
									"});",
									"",
									"if (json.data && json.data.access_token) {",
									"  pm.environment.set('accessToken', json.data.access_token);",
									"  pm.environment.set('refreshToken', json.data.refresh_token);",
									"  console.log('✅ Tokens rotated and saved to environment');",
									"}"
								]
							}
						}
					],
					"response": [
						{
							"name": "200 OK — Token Rotated",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"status\": \"success\",\n  \"code\": 200,\n  \"data\": {\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...(baru)\",\n    \"token_type\": \"Bearer\",\n    \"expires_in\": 3600,\n    \"refresh_token\": \"uuid-baru...\",\n    \"scope\": \"read write\"\n  },\n  \"message\": \"Token refreshed successfully\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						},
						{
							"name": "401 Invalid Refresh Token",
							"status": "Unauthorized",
							"code": 401,
							"body": "{\n  \"status\": \"error\",\n  \"code\": 401,\n  \"message\": \"Invalid or expired refresh token\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Introspect Token (valid)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Basic c21hcnRjaXR5LWFwcDpzbWFydGNpdHktc2VjcmV0",
								"description": "base64('smartcity-app:smartcity-secret')"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{accessToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/introspect",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "introspect"]
						},
						"description": "Dipakai Gateway secara internal untuk memvalidasi token.\nHeader Authorization menggunakan Basic Auth: base64(clientId:clientSecret).\n\nJalankan 'Password Grant' dulu agar {{accessToken}} terisi."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Token is active', () => {",
									"  pm.expect(json.active).to.be.true;",
									"});",
									"",
									"pm.test('Has username', () => {",
									"  pm.expect(json).to.have.property('username');",
									"});",
									"",
									"pm.test('Has role', () => {",
									"  pm.expect(json).to.have.property('role');",
									"});",
									"",
									"pm.test('Has exp (expiry)', () => {",
									"  pm.expect(json).to.have.property('exp');",
									"});",
									"",
									"pm.test('Has client_id', () => {",
									"  pm.expect(json).to.have.property('client_id');",
									"});"
								]
							}
						}
					],
					"response": [
						{
							"name": "200 OK — Token Active",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"active\": true,\n  \"sub\": \"1\",\n  \"username\": \"admin\",\n  \"role\": \"admin\",\n  \"client_id\": \"smartcity-app\",\n  \"scope\": \"read write\",\n  \"exp\": 1234567890\n}"
						},
						{
							"name": "200 — Token Inactive",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"active\": false\n}"
						}
					]
				},
				{
					"name": "Introspect Token (invalid/expired)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Basic c21hcnRjaXR5LWFwcDpzbWFydGNpdHktc2VjcmV0"
							}
