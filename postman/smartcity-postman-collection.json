{
	"info": {
		"_postman_id": "smartcity-platform-full",
		"name": "TrashTrack Smart City Platform",
		"description": "Full API Collection — Kelompok 6\n\nUrutan demo:\n1. Jalankan 'Login Admin' dulu → accessToken terisi otomatis\n2. Jalankan 'IoT Token' → iotToken terisi otomatis\n3. Test sesuai skenario S1–S6\n\nUsers:\n- admin / admin123 (role: admin)\n- warga1 / warga123 (role: citizen)\n\nIoT client: iot-device / iot-secret",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [],
	"item": [
		{
			"name": "0. Health Check",
			"description": "Gunakan folder ini untuk demo S4 (Docker) dan S5 (K8s) — tunjukkan semua service up.",
			"item": [
				{
					"name": "Gateway Health (5 services)",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"const json = pm.response.json();",
						"pm.test('Gateway OK', () => pm.expect(json.data.gateway).to.equal('ok'));",
						"pm.test('Overall OK', () => pm.expect(json.data.overall).to.equal('ok'));",
						"pm.test('5 upstream services', () => pm.expect(json.data.services.length).to.equal(5));"
					]}}]
				},
				{
					"name": "IoT Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/iot/status", "host": ["{{baseUrl}}"], "path": ["iot", "status"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('IoT ready', () => pm.expect(pm.response.json().message).to.include('IoT Gateway is ready'));"
					]}}]
				},
				{
					"name": "Smart Bin Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/smart-bin/health", "host": ["{{baseUrl}}"], "path": ["api", "smart-bin", "health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					]}}]
				},
				{
					"name": "Fleet Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/fleet/health", "host": ["{{baseUrl}}"], "path": ["api", "fleet", "health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					]}}]
				},
				{
					"name": "Citizen Report Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/citizen-report/health", "host": ["{{baseUrl}}"], "path": ["api", "citizen-report", "health"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));"
					]}}]
				}
			]
		},
		{
			"name": "1. OAuth (Auth)",
			"description": "Jalankan 'Login Admin' dan 'IoT Token' sebelum test lainnya.",
			"item": [
				{
					"name": "Login Admin",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has access_token', () => pm.expect(json.data).to.have.property('access_token'));",
						"pm.test('Role admin', () => {",
						"  const payload = JSON.parse(atob(json.data.access_token.split('.')[1]));",
						"  pm.expect(payload.role).to.equal('admin');",
						"});",
						"if (json.data) {",
						"  pm.environment.set('accessToken', json.data.access_token);",
						"  pm.environment.set('refreshToken', json.data.refresh_token);",
						"  console.log('accessToken saved!');",
						"}"
					]}}]
				},
				{
					"name": "Login Warga (warga1)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"username\": \"warga1\",\n  \"password\": \"warga123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has access_token', () => pm.expect(json.data).to.have.property('access_token'));",
						"pm.test('Role citizen', () => {",
						"  const payload = JSON.parse(atob(json.data.access_token.split('.')[1]));",
						"  pm.expect(payload.role).to.equal('citizen');",
						"});",
						"if (json.data) {",
						"  pm.environment.set('accessTokenWarga', json.data.access_token);",
						"  console.log('accessTokenWarga saved!');",
						"}"
					]}}]
				},
				{
					"name": "IoT Token (Client Credentials)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"{{iotClientId}}\",\n  \"client_secret\": \"{{iotClientSecret}}\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Scope is service', () => pm.expect(json.data.scope).to.equal('service'));",
						"if (json.data) {",
						"  pm.environment.set('iotToken', json.data.access_token);",
						"  console.log('iotToken saved!');",
						"}"
					]}}]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"if (json.data) {",
						"  pm.environment.set('accessToken', json.data.access_token);",
						"  pm.environment.set('refreshToken', json.data.refresh_token);",
						"}"
					]}}]
				},
				{
					"name": "Introspect Token",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Basic {{basicAuth}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{accessToken}}\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/introspect", "host": ["{{baseUrl}}"], "path": ["oauth", "introspect"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Token active', () => pm.expect(json.active).to.be.true);",
						"pm.test('Username is admin', () => pm.expect(json.username).to.equal('admin'));"
					]}}]
				},
				{
					"name": "Revoke Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{accessToken}}\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/revoke", "host": ["{{baseUrl}}"], "path": ["oauth", "revoke"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Revoked', () => pm.expect(pm.response.json().message).to.include('revoked'));"
					]}}]
				},
				{
					"name": "[401] Client Secret Salah",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"smartcity-app\",\n  \"client_secret\": \"salah-secret\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 401', () => pm.response.to.have.status(401));",
						"pm.test('Invalid client', () => pm.expect(pm.response.json().message).to.include('Invalid client'));"
					]}}]
				}
			]
		},
		{
			"name": "[S1] IoT Data Ingestion",
			"description": "Simulasi sensor tong sampah kirim telemetri lewat Gateway.\nRequires: iotToken (jalankan 'IoT Token' dulu).",
			"item": [
				{
					"name": "Telemetry Normal (BIN-Z1-01, 45%)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{iotToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bin_id\": \"BIN-Z1-01\",\n  \"fill_level\": 45.5,\n  \"gas_level\": 150,\n  \"temperature\": 30.0,\n  \"calibrated_height\": 98.0,\n  \"latitude\": -6.1944,\n  \"longitude\": 106.8318\n}"
						},
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('ML predictions exist', () => pm.expect(json.data).to.have.property('ml_predictions'));",
						"pm.test('No dispatch (fill not critical)', () => pm.expect(json.data.ml_predictions.dispatch).to.be.null);"
					]}}]
				},
				{
					"name": "Telemetry Critical → Auto-Dispatch (BIN-Z3-01, 95%)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{iotToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bin_id\": \"BIN-Z3-01\",\n  \"fill_level\": 95.0,\n  \"gas_level\": 600,\n  \"temperature\": 35.0,\n  \"calibrated_height\": 120.0,\n  \"latitude\": -6.2383,\n  \"longitude\": 106.8000\n}"
						},
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('Priority Urgent/Critical', () => {",
						"  const p = json.data.ml_predictions.priority;",
						"  pm.expect(['Urgent','Critical']).to.include(p);",
						"});",
						"if (json.data && json.data.ml_predictions && json.data.ml_predictions.dispatch) {",
						"  const sid = json.data.ml_predictions.dispatch.schedule_id;",
						"  if (sid) {",
						"    pm.environment.set('lastScheduleId', sid);",
						"    console.log('lastScheduleId saved: ' + sid);",
						"  }",
						"}"
					]}}]
				},
				{
					"name": "[401] Telemetry Tanpa Token",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bin_id\": \"BIN-Z1-01\",\n  \"fill_level\": 50.0\n}"
						},
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 401 — Unauthorized', () => pm.response.to.have.status(401));"
					]}}]
				},
				{
					"name": "[401] Telemetry Pakai Token Admin (Bukan IoT)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bin_id\": \"BIN-Z1-01\",\n  \"fill_level\": 50.0\n}"
						},
						"url": { "raw": "{{baseUrl}}/iot/telemetry", "host": ["{{baseUrl}}"], "path": ["iot", "telemetry"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 401 atau 403 — Token bukan scope service', () => {",
						"  pm.expect([401, 403]).to.include(pm.response.code);",
						"});"
					]}}]
				}
			]
		},
		{
			"name": "[S2] Citizen Report",
			"description": "Warga lapor masalah sampah. Admin verifikasi lalu dispatch truk.\nRequires: accessToken (Login Admin) atau accessTokenWarga (Login Warga).",
			"item": [
				{
					"name": "Submit Laporan Warga (form-data + foto opsional)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "reporter_name", "value": "Budi Santoso Demo", "type": "text" },
								{ "key": "reporter_phone", "value": "081234560001", "type": "text" },
								{ "key": "issue_description", "value": "Tong sampah BIN-Z1-01 meluber, butuh pengangkutan segera", "type": "text" },
								{ "key": "geo_coordinate", "value": "-6.1944,106.8318", "type": "text" },
								{ "key": "photo", "type": "file", "src": "", "disabled": true, "description": "Opsional — pilih file JPG/PNG max 2MB" }
							]
						},
						"url": { "raw": "{{baseUrl}}/api/reports", "host": ["{{baseUrl}}"], "path": ["api", "reports"] },
						"description": "Kirim laporan via form-data. Field 'photo' opsional — bisa dikosongkan untuk demo cepat."
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"pm.test('Status Pending', () => pm.expect(json.data.verification_status).to.equal('Pending'));",
						"pm.test('Reporter name correct', () => pm.expect(json.data.reporter_name).to.equal('Budi Santoso Demo'));",
						"if (json.data && json.data.id) {",
						"  pm.environment.set('lastReportId', json.data.id);",
						"  console.log('lastReportId saved: ' + json.data.id);",
						"}"
					]}}]
				},
				{
					"name": "Verify Laporan (Admin)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/api/reports/{{lastReportId}}/verify",
							"host": ["{{baseUrl}}"],
							"path": ["api", "reports", "{{lastReportId}}", "verify"]
						}
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status Reviewed', () => pm.expect(pm.response.json().data.verification_status).to.equal('Reviewed'));"
					]}}]
				},
				{
					"name": "Dispatch Armada ke Laporan",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/api/reports/{{lastReportId}}/dispatch",
							"host": ["{{baseUrl}}"],
							"path": ["api", "reports", "{{lastReportId}}", "dispatch"]
						}
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const json = pm.response.json();",
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Status Dispatched', () => pm.expect(json.data.report.verification_status).to.equal('Dispatched'));",
						"pm.test('Truck assigned', () => pm.expect(json.data.truck).to.have.property('license_plate'));"
					]}}]
				},
				{
					"name": "[401] Submit Tanpa Token",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "reporter_name", "value": "Test", "type": "text" },
								{ "key": "reporter_phone", "value": "08123456789", "type": "text" },
								{ "key": "issue_description", "value": "Sampah menumpuk", "type": "text" },
								{ "key": "geo_coordinate", "value": "-6.1944,106.8318", "type": "text" }
							]
						},
						"url": { "raw": "{{baseUrl}}/api/reports", "host": ["{{baseUrl}}"], "path": ["api", "reports"] }
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 401 — Unauthorized', () => pm.response.to.have.status(401));"
					]}}]
				}
			]
		},
		{
			"name": "[S3] ML Predictions",
			"description": "Model ML untuk prediksi fill rate, prioritas pickup, dan deteksi anomali.\nRequires: accessToken (Login Admin).",
			"item": [
				{
					"name": "Predict Fill Rate (jam berapa penuh?)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"jam\": 14,\n  \"suhu_cuaca\": 32.0,\n  \"volume_sekarang\": 45.0,\n  \"latitude\": -6.1944,\n  \"longitude\": 106.8318,\n  \"is_weekend\": 0\n}"
						},
						"url": { "raw": "{{baseUrl}}/predict/fill-rate", "host": ["{{baseUrl}}"], "path": ["predict", "fill-rate"] },
						"description": "Prediksi berapa jam lagi tong sampah akan penuh.\nField: jam (0-23), suhu_cuaca (Celcius), volume_sekarang (0-100%), latitude, longitude, is_weekend (0/1)"
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has hours_until_full', () => pm.expect(pm.response.json()).to.have.property('hours_until_full'));",
						"pm.test('hours_until_full is number', () => pm.expect(pm.response.json().hours_until_full).to.be.a('number'));"
					]}}]
				},
				{
					"name": "Predict Priority (tingkat prioritas pickup)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"volume_sekarang\": 85.0,\n  \"kadar_metana\": 30.0,\n  \"laporan_warga\": 3\n}"
						},
						"url": { "raw": "{{baseUrl}}/predict/priority", "host": ["{{baseUrl}}"], "path": ["predict", "priority"] },
						"description": "Prediksi prioritas pengambilan sampah (Low/Medium/Urgent/Critical).\nField: volume_sekarang (0-100%), kadar_metana (ppm), laporan_warga (jumlah laporan)"
					},
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('Has pickup_priority', () => pm.expect(pm.response.json()).to.have.property('pickup_priority'));",
						"pm.test('Priority valid', () => {",
						"  const p = pm.response.json().pickup_priority;",
						"  pm.expect(['Low','Medium','Urgent','Critical']).to.include(p);",
						"});"
					]}}]
				},
				{
					"name": "Predict Priority — Critical Scenario",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
