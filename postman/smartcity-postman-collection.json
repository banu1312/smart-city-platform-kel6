								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/introspect",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "introspect"]
						},
						"description": "Test dengan token palsu — harus return { active: false }"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Token is NOT active', () => {",
									"  pm.expect(json.active).to.be.false;",
									"});"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Revoke Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{accessToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{oauthUrl}}/oauth/revoke",
							"host": ["{{oauthUrl}}"],
							"path": ["oauth", "revoke"]
						},
						"description": "Cabut token. Setelah revoke, token tidak bisa dipakai lagi.\nJalankan 'Introspect Token (valid)' setelah ini untuk membuktikan token sudah tidak aktif."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const json = pm.response.json();",
									"",
									"pm.test('Status code is 200', () => {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Revoke successful', () => {",
									"  pm.expect(json.status).to.equal('success');",
									"});",
									"",
									"pm.environment.unset('accessToken');",
									"console.log('🗑️ accessToken cleared from environment');"
								]
							}
						}
					],
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"status\": \"success\",\n  \"code\": 200,\n  \"message\": \"Token revoked successfully\",\n  \"service\": \"oauth-server\",\n  \"timestamp\": \"2026-06-13T00:00:00.000Z\"\n}"
						}
					]
				},
